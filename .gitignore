# ---------------------------------------------------
# Movie Database CLI - .gitignore
# ---------------------------------------------------

# 1. Security (CRITICAL)
# Never commit your environment variables or secrets!
.env
*.env
.env.*

# 2. Compiled Binaries
# Ignore the executables we build using 'go build'
tmdb
tmdb.exe
tmdb-windows.exe
tmdb-linux
*.exe
*.out
*.app

# 3. Go Specific
# Ignore Go workspace files and test outputs
go.work
go.work.sum
*.test
*.prof

# 4. OS Specific
# Ignore noisy files generated by your operating system
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 5. IDEs and Editors
# Ignore settings folders created by VS Code, GoLand, etc.
.vscode/
.idea/
*.swp
*.swo